<?xml version="1.0" encoding="UTF-8"?>
<archimate:ArchimateModel xmlns:archimate="http://www.opengroup.org/xsd/archimate/3.1/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="test-model-multi-image" name="TestModelWithMultipleImages">
  <folder name="Business">
    <element xsi:type="archimate:BusinessActor" id="actor-1" name="Actor1"/>
    <element xsi:type="archimate:BusinessActor" id="actor-2" name="Actor2"/>
  </folder>
  <folder name="Images">
    <element xsi:type="archimate:Representation" id="img-1" name="Image1">
      <property key="image-data" value="iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="/>
    </element>
    <element xsi:type="archimate:Representation" id="img-2" name="Image2">
      <property key="image-data" value="iVBORw0KGgoAAAANSUhEUgAAAAIAAAACCAYAAABytg0kAAAAE0lEQVQI12P4z8DwHwMx+FAOBgAXnAL9Z8sOKQAAAABJRU5ErkJggg=="/>
    </element>
  </folder>
  <folder name="Views">
    <element xsi:type="archimate:ArchimateDiagramModel" id="view-1" name="TestViewMultiImage">
      <documentation>
        <content>Test view with multiple embedded images</content>
      </documentation>
      <child xsi:type="archimate:DiagramObject" id="node-1" archimateElement="actor-1">
        <bounds x="10" y="10" width="80" height="40"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="node-2" archimateElement="actor-2">
        <bounds x="100" y="10" width="80" height="40"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="node-3" archimateElement="img-1">
        <bounds x="10" y="60" width="80" height="80"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="node-4" archimateElement="img-2">
        <bounds x="100" y="60" width="80" height="80"/>
      </child>
    </element>
  </folder>
</archimate:ArchimateModel>
