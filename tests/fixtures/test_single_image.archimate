<?xml version="1.0" encoding="UTF-8"?>
<archimate:ArchimateModel xmlns:archimate="http://www.opengroup.org/xsd/archimate/3.1/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="test-model-single-image" name="TestModelWithSingleImage">
  <folder name="Business">
    <element xsi:type="archimate:BusinessActor" id="actor-1" name="TestActor"/>
  </folder>
  <folder name="Images">
    <element xsi:type="archimate:Representation" id="img-1" name="TestImage">
      <property key="image-data" value="iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg=="/>
    </element>
  </folder>
  <folder name="Views">
    <element xsi:type="archimate:ArchimateDiagramModel" id="view-1" name="TestView">
      <documentation>
        <content>Test view with embedded image</content>
      </documentation>
      <child xsi:type="archimate:DiagramObject" id="node-1" archimateElement="actor-1">
        <bounds x="10" y="10" width="80" height="40"/>
      </child>
      <child xsi:type="archimate:DiagramObject" id="node-2" archimateElement="img-1">
        <bounds x="100" y="10" width="100" height="100"/>
      </child>
    </element>
  </folder>
</archimate:ArchimateModel>
