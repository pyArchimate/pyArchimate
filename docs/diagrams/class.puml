@startuml
title pyArchimate Domain Model

class Model {
  id: str
  name: str
  desc: str
  theme: str
  elements: list[Element]
  relationships: list[Relationship]
  views: list[View]
  profiles: list[Profile]
  --
  + add(type, name, ...) : Element|View
  + add_relationship(type, source, target, ...) : Relationship
  + add_profile(name, concept, ...) : Profile
  + read(file_path)
  + write(file_path, writer)
  + merge(file_path)
  + find_elements(name, type) : list[Element]
  + get_or_create_view(name, create) : View
}

class Element {
  id: str
  name: str
  type: str
  desc: str
  folder: str
  properties: dict
  --
  + prop(key, value)
  + rels(rel_type) : list[Relationship]
  + delete()
}

class Relationship {
  id: str
  name: str
  type: str
  source: Element|Relationship
  target: Element|Relationship
  desc: str
  access_type: str
  influence_strength: str
  is_directed: bool
  --
  + prop(key, value)
  + delete()
}

class Profile {
  id: str
  name: str
  concept: str
  --
  + delete()
}

class View {
  id: str
  name: str
  desc: str
  folder: str
  nodes: list[Node]
  connections: list[Connection]
  --
  + add(ref, x, y, ...) : Node
  + add_connection(ref, source, target, ...) : Connection
  + get_or_create_node(elem, ...) : Node
}

class Node {
  id: str
  concept: Element
  cat: str {Element|Label|Container|Model}
  x, y, w, h: int
  fill_color, line_color: str
  label: str
  --
  + add(ref, ...) : Node {nested}
  + resize(...)
  + move(new_parent)
  + delete()
}

class Connection {
  id: str
  concept: Relationship
  source, target: Node
  bendpoints: list[Point]
  --
  + add_bendpoint(Point)
  + l_shape()
  + s_shape()
  + delete()
}

Model "1" *-- "*" Element : contains
Model "1" *-- "*" Relationship : manages
Model "1" *-- "*" View : owns
Model "1" o-- "*" Profile : catalogs

View "1" *-- "*" Node : hosts
View "1" *-- "*" Connection : contains

Node --> Element : visualizes
Connection --> Relationship : visualizes
Connection --> Node : source/target

Relationship --> Element : connects
Relationship --> Relationship : connects (higher-order)

Element "0..*" o-- "0..*" Profile : specialized by
Relationship "0..*" o-- "0..*" Profile : specialized by

@enduml
