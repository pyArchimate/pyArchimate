@startuml
title pyArchimate Domain Model

class Model {
  id: str
  name: str
  elements: dict[str, Element]
  relationships: dict[str, Relationship]
  views: dict[str, View]
  --
  + add(element: Element)
  + add_relationship(rel: Relationship)
  + add_profile(profile: Profile)
  + read(source, format: str)
  + write(target, format: str)
}

class Element {
  id: str
  name: str
  type: str
  properties: dict
  --
  + prop(key: str) -> Any
  + in_rels() -> List[Relationship]
  + out_rels() -> List[Relationship]
  + rels() -> List[Relationship]
}

class Relationship {
  id: str
  name: str
  type: str
  source: Element
  target: Element
  --
  + prop(key: str) -> Any
  + delete()
}

class Profile {
  id: str
  name: str
  --
  + delete()
}

class View {
  id: str
  name: str
  nodes: List[Node]
  connections: List[Connection]
  --
  + add(element: Element) -> Node
  + add_connection(rel: Relationship) -> Connection
  + delete()
}

class Node {
  id: str
  element: Element
  x: int
  y: int
  --
  + add()
  + delete()
}

class Connection {
  id: str
  relationship: Relationship
  source: Node
  target: Node
  --
  + add_bendpoint(x, y)
  + delete()
}

Model "1" *-- "*" Element : contains
Model "1" *-- "*" Relationship : manages
Model "1" *-- "*" View : owns
Model "1" o-- "*" Profile : catalogs

View "1" *-- "*" Node : hosts
View "1" *-- "*" Connection : contains

Node --> Element : visualizes
Connection --> Relationship : visualizes
Connection --> Node : source/target

Relationship --> Element : source/target

Element "0..*" o-- "0..*" Profile : tagged by

@enduml
