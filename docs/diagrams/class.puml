@startuml
title pyArchimate Class Diagram (Modular Wrapper + Legacy Core)

package "Wrapper Modules" {
  class "model.py\n<<module>>" as ModelModule {
    + re-export Model
  }
  class "element.py\n<<module>>" as ElementModule {
    + re-export Element
  }
  class "relationship.py\n<<module>>" as RelationshipModule {
    + re-export Relationship
  }
  class "pyArchimate.py\n<<compat module>>" as CompatModule {
    + re-export public API
  }
}

package "Helper Modules" {
  class "diagram.py\n<<module>>" as DiagramModule {
    + get_or_create_node(owner,...)
    + get_or_create_connection(owner,...)
  }
  class "properties.py\n<<module>>" as PropertyModule {
    + embed_props(model,...)
    + expand_props(model,...)
    + check_invalid_conn(model)
    + check_invalid_nodes(model)
  }
  class "logging.py\n<<module>>" as LoggingModule {
    + log_to_file()
    + log_to_stderr()
    + log_set_level()
  }
}

package "_legacy.py (Actual Class Definitions)" {
  class Model {
    + add()
    + add_relationship()
    + add_profile()
    + read()
    + write()
    + embed_props()
    + expand_props()
    + check_invalid_conn()
    + check_invalid_nodes()
  }
  class Element {
    + prop()
    + in_rels()
    + out_rels()
    + rels()
  }
  class Relationship {
    + prop()
    + delete()
  }
  class Profile {
    + delete()
  }
  class View {
    + add()
    + add_connection()
    + delete()
  }
  class Node {
    + add()
    + delete()
  }
  class Connection {
    + add_bendpoint()
    + delete()
  }
}

enum Readers
enum Writers

ModelModule ..> Model : re-exports
ElementModule ..> Element : re-exports
RelationshipModule ..> Relationship : re-exports
CompatModule ..> Model : re-exports
CompatModule ..> Element : re-exports
CompatModule ..> Relationship : re-exports
CompatModule ..> DiagramModule : exports helper functions
CompatModule ..> PropertyModule : exports helper functions
CompatModule ..> LoggingModule : exports helper functions

Model "1" o-- "*" Element : contains
Model "1" o-- "*" Relationship : manages
Model "1" o-- "*" View : owns
Model "1" o-- "*" Profile : catalogs
View "1" o-- "*" Node : hosts
View "1" o-- "*" Connection : connects
Node "1" *-- "*" Node : embeds
Node --> Element : refers to
Connection --> Relationship : visualizes
Connection --> Node : source/target
Relationship --> Element : source/target
Element "0..*" ..> Profile : optionally uses
Model --> Readers : uses readers
Model --> Writers : uses writers
DiagramModule --> Model : delegates
PropertyModule --> Model : delegates
LoggingModule ..> Model : emits logs
@enduml
