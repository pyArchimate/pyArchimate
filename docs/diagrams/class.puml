@startuml
title pyArchimate Domain Model

class Model {
  uuid: str
  name: str
  desc: str
  theme: str
  --
  {readonly} elements: list[Element]
  {readonly} relationships: list[Relationship]
  {readonly} views: list[View]
  {readonly} profiles: list[Profile]
  {readonly} nodes: list[Node]
  {readonly} conns: list[Connection]
  --
  + add(concept_type, name, ...) : Element|View
  + add_child(parent_uuid, child_uuid)
  + remove_child(parent_uuid, child_uuid)
  + add_relationship(rel_type, source, target, ...) : Relationship
  + add_profile(name, concept, ...) : Profile
  + read(file_path, *args, **kwargs)
  + write(file_path, writer)
  + merge(file_path)
  + find_elements(name, type) : list[Element]
  + find_relationships(rel_type, elem, direction='both') : list[Relationship]
  + find_views(name) : list[View]
  + filter_elements(fct) : list[Element]
  + filter_relationships(fct) : list[Relationship]
  + filter_views(fct) : list[View]
  + get_or_create_element(...) : Element
  + get_or_create_relationship(...) : Relationship
  + get_or_create_view(name) : View
  + get_profile(name) : Profile
  + get_parent(elem_uuid) : Optional[Element]
  + get_children(elem_uuid) : list[Element]
  + get_ancestors(elem_uuid) : list[Element]
  + get_descendants(elem_uuid) : list[Element]
  + get_siblings(elem_uuid) : list[Element]
  + get_root_elements() : list[Element]
  + get_leaf_elements() : list[Element]
  + get_depth(elem_uuid) : int
  + find_by_hierarchy_path(path) : list[Element]
  + get_viewpoints() : list[Viewpoint]
  + get_elements_by_viewpoint(viewpoint_id) : list[Element]
  + get_views_by_viewpoint(viewpoint_id) : list[View]
  + embed_props(remove_props)
  + expand_props(clean_doc)
  + check_invalid_conn() : list
  + check_invalid_nodes() : list
  + check_connection(c) : bool
  + default_theme(theme)
  + prop(key, value) : any
  + remove_prop(key)
}

class Element {
  uuid: str
  name: str
  type: str
  desc: str
  folder: str
  profile_id: str (optional)
  parent_uuid: str (optional)
  viewpoints: list[str]
  --
  {readonly} props: dict
  --
  + rels(rel_type=None) : list[Relationship]
  + in_rels(rel_type=None) : list[Relationship]
  + out_rels(rel_type=None) : list[Relationship]
  + assign_viewpoint(viewpoint_id)
  + remove_viewpoint(viewpoint_id)
  + set_fill_color(color)
  + set_line_color(color)
  + set_line_width(width)
  + set_transparency(alpha)
  + set_junction_type(type_str)
  + set_profile(profile)
  + set_visual_style(fill_color, line_color, line_width, transparency)
  + get_fill_color() : Optional[str]
  + get_line_color() : Optional[str]
  + get_line_width() : Optional[float]
  + get_transparency() : Optional[float]
  + get_junction_type() : Optional[str]
  + get_visual_style() : dict
  + reset_profile()
  + reset_visual_style()
  + prop(key, value)
  + remove_prop(key)
  + remove_folder()
  + merge(other_element)
  + delete()
}

class Relationship {
  uuid: str
  name: str
  type: str
  source: Element|Relationship
  target: Element|Relationship
  desc: str
  folder: str
  access_type: str (optional)
  influence_strength: str (optional)
  is_directed: bool
  profile_id: str (optional)
  --
  {readonly} props: dict
  --
  + set_profile(profile)
  + reset_profile()
  + prop(key, value)
  + remove_prop(key)
  + remove_folder()
  + delete()
}

class Profile {
  uuid: str
  name: str
  concept: str
  --
  + delete()
}

class View {
  uuid: str
  name: str
  desc: str
  folder: str
  primary_viewpoint: Optional[str]
  --
  {readonly} nodes: list[Node]
  {readonly} conns: list[Connection]
  --
  + add(ref, x, y, w, h, ...) : Node
  + add_connection(ref, source, target, ...) : Connection
  + get_or_create_node(elem, ...) : Node
  + get_or_create_connection(...) : Connection
  + set_primary_viewpoint(viewpoint_name)
  + prop(key, value)
  + remove_prop(key)
  + remove_folder()
  + delete()
  + to_svg(filepath) : str
  + duplicate(name) : View
}

class Node {
  uuid: str
  ref: str
  name: str
  desc: str
  type: str
  concept: Element
  x, y: int
  w, h: int
  rx, ry: float (relative to parent node)
  cx, cy: float (center coordinates)
  fill_color: Optional[str]
  line_color: Optional[str]
  opacity: int|float
  lc_opacity: int|float
  font_color: Optional[str]
  font_name: str
  font_size: int|float
  text_alignment: Optional[str]
  text_position: Optional[str]
  label_expression: Optional[str]
  border_type: Optional[str]
  icon_color: Optional[str]
  gradient: Optional[str]
  image_path: Optional[str]
  image_position: Optional[int]
  image_type: Optional[int]
  image_source: bool
  flags: int
  label: Optional[str]
  cat: str
  --
  {readonly} nodes: list[Node]
  {readonly} view: View
  {readonly} model: Model
  --
  + add(ref, x, y, w, h, ...) : Node
  + get_or_create_node(...) : Node
  + getnodes(elem_type=None) : list[Node]
  + move(new_parent)
  + resize(max_in_row, keep_kids_size, w, h, ...) : None
  + distribute_connections()
  + in_conns(rel_type=None) : list[Connection]
  + out_conns(rel_type=None) : list[Connection]
  + conns(rel_type=None) : list[Connection]
  + is_inside(x, y) : bool
  + delete()
}

class Connection {
  uuid: str
  ref: str
  line_color: Optional[str]
  font_color: Optional[str]
  font_name: str
  font_size: int|float
  line_width: float
  text_position: str
  show_label: bool
  --
  {readonly} bendpoints: list[Point]
  {readonly} name: str (from concept)
  {readonly} type: str (from concept)
  {readonly} concept: Relationship
  {readonly} source, target: Node
  {readonly} access_type: str (from concept)
  {readonly} influence_strength: str (from concept)
  {readonly} is_directed: bool (from concept)
  --
  + add_bendpoint(*bendpoints)
  + set_bendpoint(bp, index)
  + del_bendpoint(index)
  + get_bendpoint(index) : Point
  + get_all_bendpoints() : list[Point]
  + remove_all_bendpoints()
  + l_shape(direction, weight_x, weight_y)
  + s_shape(direction, weight_x, weight_y, weight2)
  + delete()
}

class Point {
  x: int
  y: int
  idx: int
  start_x: Optional[int]
  start_y: Optional[int]
  end_x: Optional[int]
  end_y: Optional[int]
}

class Position {
  dx: float
  dy: float
  gap_x: float
  gap_y: float
  angle: float
  orientation: str
  --
  {readonly} dist: float
}

Model "1" *-- "*" Element : contains
Model "1" *-- "*" Relationship : manages
Model "1" *-- "*" View : owns
Model "1" o-- "*" Profile : catalogs

Element "0..*" -- "0..*" Element : parent-child hierarchy
View "1" *-- "*" Node : hosts
View "1" *-- "*" Connection : contains

Node "1" o-- "*" Node : nested nodes

Node --> Element : visualizes
Connection --> Relationship : visualizes
Connection --> Node : links

Relationship --> Element : connects source/target
Relationship --> Relationship : higher-order relationships

Element "0..*" o-- "0..*" Profile : specialized by
Relationship "0..*" o-- "0..*" Profile : specialized by

Connection "0..*" -- "*" Point : defines path

