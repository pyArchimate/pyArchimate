@startuml
!includeurl <C4/C4_Component>
title pyArchimate Component Diagram
LAYOUT_WITH_LEGEND()

Container(pyArchimateLib, "pyArchimate library", "Python", "Handles creation/serialization of models")

Component(modelMod, "Model Module", "model.py", "Core class (Model) for elements, relationships, and model-level operations")
Component(viewMod, "View Module", "view.py", "Visual structures (View, Node, Connection) for diagramming")
Component(readerRegistry, "Reader Registry", "constants.py", "Dispatches Archi/Archimate/ARIS readers via MODEL_READER_REGISTRY")
Component(writerRegistry, "Writer Registry", "writers/", "Routes model exports for Archimate, Archi, CSV via WRITER_REGISTRY")
Component(logging, "Logging Subsystem", "logger.py", "Standardized logging across core and IO layers")
Component(helpers, "Helper Modules", "helpers/", "Property validation and diagram utility wrappers")

Rel(modelMod, viewMod, "Owns views; coordinates node creation")
Rel(modelMod, readerRegistry, "Loads readers")
Rel(modelMod, writerRegistry, "Invokes writers")
Rel(modelMod, helpers, "Delegates validation")
Rel(readerRegistry, logging, "Logs parsing issues")
Rel(writerRegistry, logging, "Logs export results")

@enduml
