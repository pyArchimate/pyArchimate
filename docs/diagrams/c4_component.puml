@startuml
!includeurl <C4/C4_Component>
title pyArchimate Component Diagram
LAYOUT_WITH_LEGEND()

Container(pyArchimateLib, "pyArchimate library", "Python", "Handles creation/serialization of models")

Component(modelManager, "Model Manager", "Python class", "Creates model, elements, relationships, profiles")
Component(viewManager, "View Manager", "Python class", "Manages views, nodes, connections")
Component(readerFacade, "Reader Facade", "Python module", "Dispatches Archi/Archimate/ARIS readers")
Component(writerFacade, "Writer Facade", "Python module", "Routes model exports for Archimate, Archi, CSV")
Component(logging, "Logging", "pyArchimate.logger", "Emits CLI + core logs")
Component(profileHelper, "Profile Manager", "Python class", "Creates/links profiles for elements")

Rel(modelManager, viewManager, "Provides elements/views")
Rel(modelManager, readerFacade, "Accepts parsed data")
Rel(modelManager, writerFacade, "Feeds models for serialization")
Rel(modelManager, profileHelper, "Controls profiles")
Rel(readerFacade, logging, "Logs warnings during parsing")
Rel(writerFacade, logging, "Logs exports")

@enduml
