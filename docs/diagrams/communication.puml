@startuml
title Communication Diagram for Model Construction

actor "CLI / Script" as CLI
participant "Model" as Model
participant "Element" as Element
participant "Relationship" as Relationship
participant "View" as View
participant "Node" as Node
participant "Connection" as Connection

CLI -> Model ++ : 1: add(type, name)
Model -> Element ** : 2: create and register
Model -> CLI -- : Element

CLI -> Model ++ : 3: add_relationship(type, src, tgt)
Model -> Relationship ** : 4: create and register
Model -> CLI -- : Relationship

CLI -> Model ++ : 5: add(View, name)
Model -> View ** : 6: create and register
Model -> CLI -- : View

CLI -> View ++ : 7: add(element)
View -> Node ** : 8: create for element
Node -> Element : 9: references
View -> CLI -- : Node

CLI -> View ++ : 10: add_connection(rel, src_node, tgt_node)
View -> Connection ** : 11: create for relationship
Connection -> Relationship : 12: references
Connection -> Node : 13: connects source/target
View -> CLI -- : Connection

@enduml
