@startuml
title pyArchimate Package Structure

package "pyArchimate" {
  class "pyArchimate.py" as Facade {
    {Public API Shim}
  }

  class "model.py" as ModelMod {
    class Model
  }

  package "view" as ViewMod {
    class "__init__.py" as ViewInit {
      class View
      class Node
      class Connection
      class Profile
      class Point
      class Position
    }
    package "layout" as LayoutPkg {
      class "core.py" as LayoutCore
      package "algorithms" {
        class "force_directed.py"
        class "hierarchical.py"
      }
      package "export" {
        class "svg_export.py" as SvgExport {
          class SVGExportService
        }
        package "symbols" {
          class "archimate_symbols.py" as ArchSymbols {
            NamedTuple SymbolDefinition
          }
          class "archimate_relationships.py" as ArchRels {
            NamedTuple RelationshipStyle
            class RelationshipStyleService
          }
          class "color_palette.py" as ColorPal {
            class ColorPalette
          }
        }
      }
      package "format" {
        class "element_format.py"
      }
      package "routing" {
        class "orthogonal.py"
        class "label_placement.py"
        class "layer_constraints.py"
      }
      package "utils" {
        class "geometry.py"
        class "graph.py"
        class "edge_utils.py"
      }
    }
  }

  class "element.py" as ElementMod {
    class Element
  }

  class "relationship.py" as RelationshipMod {
    class Relationship
  }

  class "viewpoint.py" as ViewpointMod {
    class Viewpoint
  }

  class "viewpoint_registry.py" as ViewpointRegistry

  class "constants.py" as Constants
  class "enums.py" as Enums
  class "exceptions.py" as Exceptions
  class "logger.py" as Logger

  package "helpers" {
    class "diagram.py" as DiagramHelper
    class "properties.py" as PropertiesHelper
    class "logging.py" as LoggingHelper
    class "parsing.py" as ParsingHelper
  }

  package "readers" {
    class "_archireader_helpers.py" as ArchiReaderHelpers
    class "_arisamlreader_helpers.py" as ArisAMLHelpers
    class "archiReader.py" as ArchiReader
    class "archimateReader.py" as ArchimateReader
    class "arisAMLreader.py" as ArisAMLReader
  }

  package "writers" {
    class "archimateWriter.py" as ArchimateWriter
    class "archiWriter.py" as ArchiWriter
    class "csvWriter.py" as CsvWriter
  }
}

Facade --> ModelMod : exports
Facade --> ViewInit : exports
Facade --> ElementMod : exports
Facade --> RelationshipMod : exports
Facade --> Enums : exports
Facade --> Exceptions : exports
Facade --> Constants : exports
Facade --> helpers : exports

ModelMod ..> ViewInit : references
ViewInit ..> ModelMod : references
ModelMod --> readers : uses
ModelMod --> writers : uses
ModelMod --> ViewpointRegistry : uses

readers ..> ModelMod : populates
writers ..> ModelMod : serializes

ArchiReader --> ArchiReaderHelpers : uses
ArchimateReader --> ArchiReaderHelpers : uses
ArisAMLReader --> ArisAMLHelpers : uses

ModelMod --> Constants : uses
ViewInit --> Constants : uses
ElementMod --> Constants : uses
RelationshipMod --> Constants : uses
ViewpointMod --> Constants : uses

ElementMod --> Enums : uses
RelationshipMod --> Enums : uses
ViewInit --> Enums : uses

ViewInit --> LayoutPkg : delegates SVG export

@enduml
