@startuml
title pyArchimate Package Structure

package "pyArchimate" {
  class "pyArchimate.py" as Facade {
    {Public API Shim}
  }

  class "model.py" as ModelMod {
    class Model
  }

  class "view.py" as ViewMod {
    class View
    class Node
    class Connection
    class Profile
    class Point
    class Position
  }

  class "element.py" as ElementMod {
    class Element
  }

  class "relationship.py" as RelationshipMod {
    class Relationship
  }

  class "constants.py" as Constants
  class "enums.py" as Enums
  class "exceptions.py" as Exceptions
  class "logger.py" as Logger

  package "helpers" {
    class "diagram.py" as DiagramHelper
    class "properties.py" as PropertiesHelper
    class "logging.py" as LoggingHelper
  }

  package "readers" {
    class archiReader
    class archimateReader
    class arisAMLreader
  }

  package "writers" {
    class archimateWriter
    class archiWriter
    class csvWriter
  }
}

Facade --> ModelMod : exports
Facade --> ViewMod : exports
Facade --> ElementMod : exports
Facade --> RelationshipMod : exports
Facade --> Enums : exports
Facade --> Exceptions : exports

ModelMod ..> ViewMod : references
ViewMod ..> ModelMod : references
ModelMod --> readers : uses
ModelMod --> writers : uses

readers ..> ModelMod : populates
writers ..> ModelMod : serializes

ModelMod --> Constants : uses
ViewMod --> Constants : uses
ElementMod --> Constants : uses
RelationshipMod --> Constants : uses

@enduml
