@startuml
title pyArchimate Package Structure

package "pyArchimate" {
  class "__init__.py" as Init {
    {package entry point}
  }

  class "model.py" as Model {
    class Model
  }

  class "element.py" as Element {
    class Element
  }

  class "relationship.py" as Relationship {
    class Relationship
  }

  package "helpers" {
    class "diagram.py" as DiagramHelper {
      + get_or_create_node()
      + get_or_create_connection()
    }
    class "properties.py" as PropertiesHelper {
      + embed_props()
      + expand_props()
      + check_invalid_conn()
      + check_invalid_nodes()
    }
    class "logging.py" as LoggingHelper {
      + log_to_file()
      + log_to_stderr()
      + log_set_level()
    }
  }

  package "readers" {
    class archiReader
    class archimateReader
    class arisAMLreader
  }

  package "writers" {
    class archimateWriter
    class archiWriter
    class csvWriter
  }

  class "logger.py" as Logger
}

Init --> Model : exports
Init --> Element : exports
Init --> Relationship : exports
Init --> DiagramHelper : exports
Init --> PropertiesHelper : exports
Init --> LoggingHelper : exports
Init --> readers : imports from
Init --> writers : imports from

DiagramHelper --> Logger : uses
LoggingHelper --> Logger : wraps

@enduml
